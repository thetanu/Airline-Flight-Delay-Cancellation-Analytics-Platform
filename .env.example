# Database Configuration Settings
# By default, the application uses a local SQLite database for ease of setup.
# To connect to your MySQL database (supported by MySQL Workbench), uncomment the MySQL line 
# and fill in your connection details: username, password, host (usually localhost), port (usually 3306), and database name.

# Default: SQLite (Local File)
DATABASE_URL=sqlite:///sql_database/airline_analytics.db

# MySQL Connection Example:
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/airline_db
